# Local dev: leave VITE_API_URL empty to use Vite proxy to localhost:4000.
# Production (Railway): set to your API origin (no trailing slash).
# VITE_API_URL=https://api.aamantran.online
VITE_API_URL=

# Guest invitation links (served by backend /s/...). Production:
# VITE_PUBLIC_INVITE_BASE_URL=https://api.aamantran.online
VITE_PUBLIC_INVITE_BASE_URL=http://localhost:4000
